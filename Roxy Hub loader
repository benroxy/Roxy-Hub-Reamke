-- [[ ROXY HUB | WINDUI & JUNKIE INTEGRATED LOADER ]] --

-- 1. WindUI ve Junkie SDK Yükleme
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()
local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()

-- Junkie Ayarları
Junkie.service = "RoxyHub"
Junkie.identifier = "1035974" -- Senin Junkie Panel ID'n
Junkie.provider = "RoxyHub loader"

-- 2. WindUI İçin Junkie Servisini Tanımlama
WindUI.Services.junkiedevelopment = {
    Name = "Junkie Development", 
    Icon = "shield-check",
    Args = { "ServiceId", "ApiKey", "Provider" },

    New = function()
        local function Verify(key)
            local result = Junkie.check_key(key)
            if result and result.valid then
                if result.message == "KEYLESS" then
                    getgenv().SCRIPT_KEY = "KEYLESS"
                    return true, "Keyless mode activated"
                elseif result.message == "KEY_VALID" then
                    getgenv().SCRIPT_KEY = key
                    return true, "Key is valid!"
                else
                    return false, "Invalid key provided"
                end
            end
            return false, "Verification failed"
        end

        local function Copy()
            local link = Junkie.get_key_link()
            if setclipboard then setclipboard(link) end
            return link
        end

        return { Verify = Verify, Copy = Copy }
    end
}

-- 3. WindUI Penceresini Oluşturma (Key System Dahil)
local Window = WindUI:CreateWindow({
    Title = "Roxy Hub | Premium Loader",
    Theme = "Dark",
    Transparent = true,
    Resizable = true,

    KeySystem = {
        Note = "Enter your Roxy Hub key to continue.",
        SaveKey = true, -- Anahtarı hatırlar, her seferinde sormaz
        API = {
            {
                Title = "Roxy Key System",
                Desc  = "Click to copy key link (" .. Junkie.service .. ")",
                Icon  = "key-round",
                Type  = "junkiedevelopment"
            }
        }
    }
})

-- 4. Key Doğrulanana Kadar Bekle
while not getgenv().SCRIPT_KEY do
    task.wait(0.1)
end

-- 5. Oyun Kontrolü ve Yükleme Mantığı
local PlaceId = game.PlaceId
local BaseURL = "https://raw.githubusercontent.com/benroxy/Roxy-Hub-Reamke/refs/heads/main/"

local Games = {
    [10449761463] = "RoxyHubRemakeTsb", -- The Strongest Battlegrounds
    [124473577469410] = "Roxy%20Hub%20Be-a-Lucky-Block%20SCR%C4%B0PT", -- Lucky Block
    [142823291] = "Roxy%20Hub%20Murder-Mystery-2" -- MM2
}

-- Key doğrulandıktan sonra oyunu çek
if Games[PlaceId] then
    -- Bildirim gönder (WindUI tarzı)
    WindUI:Notify({
        Title = "Roxy Hub",
        Content = "Access Granted! Loading script...",
        Duration = 3
    })
    
    task.wait(1)
    loadstring(game:HttpGet(BaseURL .. Games[PlaceId]))()
else
    -- Desteklenmeyen oyun bildirimi
    WindUI:Notify({
        Title = "Error",
        Content = "Game ID (" .. PlaceId .. ") is not supported by Roxy Hub.",
        Duration = 5
    })
end
