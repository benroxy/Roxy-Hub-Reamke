-- [[ ROXY HUB | CLEAN GHOST LOADER ]] --

local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()
local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()

-- Junkie Config
Junkie.service = "RoxyHub"
Junkie.identifier = "1035974"
Junkie.provider = "RoxyHub loader"

-- Game Database
local PlaceId = game.PlaceId
local BaseURL = "https://raw.githubusercontent.com/benroxy/Roxy-Hub-Reamke/refs/heads/main/"

local Games = {
    [10449761463] = "RoxyHubRemakeTsb",
    [124473577469410] = "Roxy%20Hub%20Be-a-Lucky-Block%20SCR%C4%B0PT",
    [142823291] = "Roxy%20Hub%20Murder-Mystery-2"
}

-- Junkie Service Definition
WindUI.Services.junkiedevelopment = {
    Name = "Junkie Development", 
    Icon = "shield-check",
    Args = { "ServiceId", "ApiKey", "Provider" },

    New = function()
        return {
            Verify = function(key)
                local result = Junkie.check_key(key)
                if result and result.valid then
                    getgenv().SCRIPT_KEY = (result.message == "KEYLESS") and "KEYLESS" or key
                    return true, "Success"
                end
                return false, "Invalid Key"
            end,
            Copy = function()
                local link = Junkie.get_key_link()
                if setclipboard then setclipboard(link) end
                return link
            end
        }
    end
}

-- Initialize Loader
local Window = WindUI:CreateWindow({
    Title = "Roxy Hub Premium",
    Theme = "Dark",
    Transparent = true,
    Resizable = true,

    KeySystem = {
        Note = "Roxy Hub - Access Required",
        SaveKey = true,
        API = {
            {
                Title = "Get Key",
                Desc  = "Copy link to clipboard",
                Icon  = "key-round",
                Type  = "junkiedevelopment"
            }
        }
    }
})

-- Silent Mode
Window:Close()

-- Verification Loop
repeat task.wait(0.2) until getgenv().SCRIPT_KEY ~= nil

-- Script Deployment
if Games[PlaceId] then
    WindUI:Notify({
        Title = "Roxy Hub",
        Content = "Authenticated. Loading script...",
        Duration = 3
    })
    
    task.wait(0.5)
    loadstring(game:HttpGet(BaseURL .. Games[PlaceId]))()
else
    WindUI:Notify({
        Title = "Error",
        Content = "Current game is not supported.",
        Duration = 5
    })
end
